# Production env for /data/ECOD/html/tricyp_app. Copy to .env.production
# (gitignored) at the project root and fill in DB_PASSWORD before
# starting the standalone server via scripts/start-production.sh.
#
# Both build (next.config.ts reads BASE_PATH at build time) and runtime
# (db credentials + bind config) consume this file.

# Public-base path the Apache reverse proxy mounts the app under.
# Apache forwards /tricyp/* unchanged, so the app's basePath must match
# for asset URLs to resolve under /tricyp/_next/* etc. Read by
# next.config.ts → NEXT_PUBLIC_BASE_PATH for client code.
BASE_PATH=/tricyp

DB_HOST=sangala
DB_PORT=45000
DB_NAME=tricyp
DB_USER=ecod
DB_PASSWORD=__set_me__

# Pool tuning. Defaults are the pg client's defaults; tune higher only
# if request concurrency starts queueing on connection acquisition.
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000

# Standalone server bind. 0.0.0.0 so Apache on prodata can reach this
# port over the LAN (matches the ecod2_app pattern on sangala).
PORT=3003
HOSTNAME=0.0.0.0
