# Production env for /data/ecod/tricyp. Copy to /data/ecod/tricyp/.env.local
# (gitignored) and fill in DB_PASSWORD before starting the systemd unit.

DB_HOST=sangala
DB_PORT=45000
DB_NAME=tricyp
DB_USER=ecod
DB_PASSWORD=__set_me__

# Public-base path the Apache reverse proxy mounts the app under.
# Apache strips /tricyp before forwarding, so the app's basePath
# must match for asset URLs to resolve under /tricyp/_next/* etc.
NEXT_PUBLIC_BASE_PATH=/tricyp

# Standalone Next.js server listens on this port; matches the
# ProxyPass target in deploy/apache-tricyp.conf.
PORT=3003
HOSTNAME=127.0.0.1
